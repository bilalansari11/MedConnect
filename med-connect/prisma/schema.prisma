enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ApptStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ApptType {
  VIDEO
  IN_PERSON
  PHONE
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}
