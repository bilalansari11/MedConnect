generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  image         String?
  role          Role           @default(PATIENT)
  createdAt     DateTime       @default(now())
  password      String?
  doctor        Doctor?
  patient       Patient?
  symptomChecks SymptomCheck[]
}

model Doctor {
  id             String        @id @default(cuid())
  userId         String        @unique
  specialization String
  qualifications String
  experience     Int
  fee            Int
  bio            String?
  rating         Float         @default(0)
  isAvailable    Boolean       @default(true)
  appointments   Appointment[]
  user           User          @relation(fields: [userId], references: [id])
  availableSlots Slot[]
}

model Patient {
  id             String        @id @default(cuid())
  userId         String        @unique
  dateOfBirth    DateTime?
  bloodGroup     String?
  allergies      String[]
  medicalHistory String?
  appointments   Appointment[]
  user           User          @relation(fields: [userId], references: [id])
}

model Appointment {
  id           String     @id @default(cuid())
  doctorId     String
  patientId    String
  date         DateTime
  timeSlot     String
  status       ApptStatus @default(PENDING)
  type         ApptType   @default(VIDEO)
  symptoms     String?
  prescription String?
  notes        String?
  createdAt    DateTime   @default(now())
  doctor       Doctor     @relation(fields: [doctorId], references: [id])
  patient      Patient    @relation(fields: [patientId], references: [id])
}

model Slot {
  id        String    @id @default(cuid())
  doctorId  String
  day       DayOfWeek
  startTime String
  endTime   String
  isBooked  Boolean   @default(false)
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
}

model SymptomCheck {
  id        String   @id @default(cuid())
  userId    String
  symptom   String
  advice    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ApptStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ApptType {
  VIDEO
  IN_PERSON
  PHONE
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}
